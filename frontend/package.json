{
  "name": "autovoice-frontend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "node ./node_modules/vite/bin/vite.js",
    "build": "node ./node_modules/typescript/bin/tsc && node ./node_modules/vite/bin/vite.js build",
    "typecheck": "node ./node_modules/typescript/bin/tsc --noEmit",
    "preview": "node ./node_modules/vite/bin/vite.js preview",
    "lint": "eslint src --ext ts,tsx",
    "test:e2e": "playwright test --config=playwright.config.ts",
    "test:e2e:live": "playwright test --config=playwright.live.config.ts",
    "test:e2e:headed": "playwright test --config=playwright.config.ts --headed"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.0.0",
    "chart.js": "^4.4.0",
    "clsx": "^2.1.0",
    "lucide-react": "^0.300.0",
    "react": "^18.2.0",
    "react-chartjs-2": "^5.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.20.0",
    "socket.io-client": "^4.7.0",
    "wavesurfer.js": "^7.4.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.37.0",
    "@playwright/test": "^1.59.1",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.2.0",
    "autoprefixer": "^10.4.0",
    "eslint": "^9.37.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.4.0",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0",
    "typescript-eslint": "^8.46.0",
    "typescript": "^5.3.0",
    "vite": "^5.0.0"
  }
}
