            "url": {
              "raw": "{{base_url}}/api/{{api_version}}/health",
              "host": ["{{base_url}}"],
              "path": ["api", "{{api_version}}", "health"]
            },
            "description": "Check system health and component status"
          },
          "response": []
        },
        {
          "name": "GPU Metrics",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/{{api_version}}/gpu/metrics",
              "host": ["{{base_url}}"],
              "path": ["api", "{{api_version}}", "gpu", "metrics"]
            },
            "description": "Get GPU utilization and memory metrics"
          },
          "response": []
